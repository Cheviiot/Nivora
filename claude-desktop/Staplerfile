	cp -a "${srcdir}/extracted/usr/lib/claude-desktop" "${pkgdir}/usr/lib/"
	chmod 0755 "${pkgdir}/usr/lib/claude-desktop/chrome-sandbox"
	chmod 755 \
		"${pkgdir}/usr/lib/claude-desktop/claude-desktop" \
		"${pkgdir}/usr/lib/claude-desktop/resources/chrome-native-host" \
		"${pkgdir}/usr/lib/claude-desktop/resources/cowork-linux-helper" \
		"${pkgdir}/usr/lib/claude-desktop/resources/virtiofsd"

	# Upstream resolves claude_desktop_config.json below Electron userData. Allow
	# account 2 to use account 1's MCP/preferences file without sharing OAuth state.
	python3 - "${pkgdir}/usr/lib/claude-desktop/resources/app.asar" <<'PY'
import copy
import hashlib
import json
import re
import struct
import sys
from pathlib import Path

asar_path = Path(sys.argv[1])
data = asar_path.read_bytes()
if len(data) < 16:
    raise SystemExit("Claude app.asar is too small")

_, _, _, header_size = struct.unpack("<IIII", data[:16])
header = json.loads(data[16 : 16 + header_size])
base_offset = 16 + ((header_size + 3) & ~3)
output = bytearray()
matches = []
identifier = rb"[A-Za-z_$][A-Za-z0-9_$]*"
config_constant_pattern = re.compile(
    rb"(" + identifier + rb')="claude_desktop_config\.json"'
)


def integrity_for(content: bytes, block_size: int = 4194304) -> dict:
    blocks = [
        hashlib.sha256(content[index : index + block_size]).hexdigest()
        for index in range(0, len(content), block_size)
    ]
    if not blocks:
        blocks = [hashlib.sha256(b"").hexdigest()]
    return {
        "algorithm": "SHA256",
        "hash": hashlib.sha256(content).hexdigest(),
        "blockSize": block_size,
        "blocks": blocks,
    }


def patch_config_paths(content: bytes, path: str) -> tuple[bytes, list[str]]:
    replacements = []
    patched_functions = []
    for constant in config_constant_pattern.finditer(content):
        config_name = re.escape(constant.group(1))
        function_pattern = re.compile(
            rb"function ("
            + identifier
            + rb")\(\)\{return ("
            + identifier
            + rb")\.join\(("
            + identifier
            + rb")\(\),"
            + config_name
            + rb"\)\}"
        )
        functions = list(
            function_pattern.finditer(
                content,
                constant.end(),
                min(len(content), constant.end() + 4096),
            )
        )
        if len(functions) != 1:
            raise SystemExit(
                f"expected one config path function near {path}, got {len(functions)}"
            )
        function = functions[0]
        original = function.group(0)
        replacement = original.replace(
            b"{return ",
            b"{return process.env.CLAUDE_DESKTOP_CONFIG_FILE||",
            1,
        )
        replacements.append((function.start(), function.end(), replacement))
        patched_functions.append(f"{path}:{function.group(1).decode()}")

    if len({(start, end) for start, end, _ in replacements}) != len(replacements):
        raise SystemExit(f"duplicate shared config patch target in {path}")
    for start, end, replacement in sorted(replacements, reverse=True):
        content = content[:start] + replacement + content[end:]
    return content, patched_functions


def rebuild_node(node: dict, prefix: str = "") -> dict:
    rebuilt = {}
    for name, child in node.get("files", {}).items():
        path = f"{prefix}/{name}" if prefix else name
        if "files" in child:
            rebuilt[name] = {
                **{key: value for key, value in child.items() if key != "files"},
                "files": rebuild_node(child, path),
            }
            continue

        entry = copy.deepcopy(child)
        if entry.get("unpacked"):
            rebuilt[name] = entry
            continue

        offset = int(entry["offset"])
        size = int(entry["size"])
        content = data[base_offset + offset : base_offset + offset + size]
        content, patched = patch_config_paths(content, path)
        if patched:
            entry["size"] = len(content)
            entry["integrity"] = integrity_for(
                content,
                entry.get("integrity", {}).get("blockSize", 4194304),
            )
            matches.extend(patched)

        entry["offset"] = str(len(output))
        output.extend(content)
        rebuilt[name] = entry

    return rebuilt


rebuilt_header = {"files": rebuild_node(header)}
if not matches:
    raise SystemExit("shared Claude config patch matched no functions")

header_bytes = json.dumps(rebuilt_header, separators=(",", ":")).encode("utf-8")
header_padded_size = (len(header_bytes) + 3) & ~3
patched_data = (
    struct.pack("<IIII", 4, header_padded_size + 8, header_padded_size + 4, len(header_bytes))
    + header_bytes
    + (b"\0" * (header_padded_size - len(header_bytes)))
    + bytes(output)
)
override_count = patched_data.count(b"CLAUDE_DESKTOP_CONFIG_FILE")
if override_count != len(matches):
    raise SystemExit(
        f"shared Claude config override count mismatch: {override_count} != {len(matches)}"
    )
asar_path.write_bytes(patched_data)
PY

