package() {
	cd "${srcdir}"

	mkdir -p "${srcdir}/extracted"
	ar x opencode.deb
	tar -xf data.tar.* -C "${srcdir}/extracted"

	install -dm755 "${pkgdir}/opt"
	cp -a "${srcdir}/extracted/opt/OpenCode" "${pkgdir}/opt/"
	chmod 0755 "${pkgdir}/opt/OpenCode/chrome-sandbox"
	chmod 755 "${pkgdir}/opt/OpenCode/ai.opencode.desktop"

	install -dm755 "${pkgdir}/usr/share"
	cp -a "${srcdir}/extracted/usr/share/applications" "${pkgdir}/usr/share/"
	cp -a "${srcdir}/extracted/usr/share/icons" "${pkgdir}/usr/share/"

	sed -i 's#Exec=/opt/OpenCode/ai.opencode.desktop#Exec=/usr/bin/opencode-desktop#' \
		"${pkgdir}"/usr/share/applications/*.desktop

	install -dm755 "${pkgdir}/usr/lib/opencode-desktop"
	install -Dm755 "${srcdir}/opencode-desktop-wrapper" \
		"${pkgdir}/usr/lib/opencode-desktop/opencode-desktop-wrapper"
	install -Dm755 "${srcdir}/opencode-desktop-doctor" \
		"${pkgdir}/usr/lib/opencode-desktop/opencode-desktop-doctor"
	install -Dm755 "${srcdir}/opencode-desktop-reset-state" \
		"${pkgdir}/usr/lib/opencode-desktop/opencode-desktop-reset-state"

	install -dm755 "${pkgdir}/usr/bin"
	ln -sfn /usr/lib/opencode-desktop/opencode-desktop-wrapper "${pkgdir}/usr/bin/opencode-desktop"
	ln -sfn /usr/lib/opencode-desktop/opencode-desktop-doctor "${pkgdir}/usr/bin/opencode-desktop-doctor"
	ln -sfn /usr/lib/opencode-desktop/opencode-desktop-reset-state "${pkgdir}/usr/bin/opencode-desktop-reset-state"
	install-license "${srcdir}/LICENSE" "opencode/LICENSE.nivora"
}

files() {
	files-find-binary
	files-find-desktop
	files-find-license
	files-find \
		"/opt/OpenCode/**/*" \
		"/usr/lib/opencode-desktop/*" \
		"/usr/share/icons/hicolor/*/apps/ai.opencode.desktop.png"
}
