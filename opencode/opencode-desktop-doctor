#!/bin/bash
set -euo pipefail

config_home="${XDG_CONFIG_HOME:-${HOME}/.config}"
cache_home="${XDG_CACHE_HOME:-${HOME}/.cache}"
data_home="${XDG_DATA_HOME:-${HOME}/.local/share}"

desktop_config="${config_home}/ai.opencode.desktop"
cli_config="${config_home}/opencode"
cache_dir="${cache_home}/opencode"
data_dir="${data_home}/opencode"
db_file="${data_dir}/opencode.db"

human_size() {
    if [[ -e "$1" ]]; then
        du -sh "$1" 2>/dev/null | awk '{print $1}'
    else
        echo "нет"
    fi
}

echo "OpenCode Desktop diagnostics"
echo
echo "Память процессов:"
ps -eo pid,ppid,rss,pmem,comm,args --sort=-rss |
    awk 'NR == 1 || $5 ~ /^ai\.opencode/ || ($5 == "chrome_crashpad" && /OpenCode/) {print}'

echo
echo "Каталоги:"
printf '  %-34s %s\n' "${desktop_config}" "$(human_size "$desktop_config")"
printf '  %-34s %s\n' "${cache_dir}" "$(human_size "$cache_dir")"
printf '  %-34s %s\n' "${data_dir}" "$(human_size "$data_dir")"
printf '  %-34s %s\n' "${cli_config}" "$(human_size "$cli_config")"

if [[ -f "$db_file" ]]; then
    echo
    echo "SQLite:"
    printf '  %-34s %s\n' "${db_file}" "$(human_size "$db_file")"

    if command -v sqlite3 >/dev/null 2>&1; then
        if ! sqlite3 "$db_file" 2>/dev/null <<'SQL'
.headers on
.mode column
SELECT 'event' AS table_name, count(*) AS rows FROM event
UNION ALL SELECT 'part', count(*) FROM part
UNION ALL SELECT 'message', count(*) FROM message
UNION ALL SELECT 'session', count(*) FROM session;
SELECT name, sum(pgsize) AS bytes
FROM dbstat
GROUP BY name
ORDER BY bytes DESC
LIMIT 8;
SQL
        then
            echo "  Не удалось прочитать часть диагностических таблиц SQLite." >&2
        fi
    else
        echo "  sqlite3 не найден, таблицы не проверены."
    fi
fi

echo
echo "Предохранители запуска:"
echo "  OPENCODE_DESKTOP_MEMORY_MAX=${OPENCODE_DESKTOP_MEMORY_MAX:-4G}"
echo "  OPENCODE_DESKTOP_MEMORY_HIGH=${OPENCODE_DESKTOP_MEMORY_HIGH:-3G}"
echo "  OPENCODE_DESKTOP_JS_HEAP_MB=${OPENCODE_DESKTOP_JS_HEAP_MB:-1536}"
echo
echo "Восстановление без удаления данных:"
echo "  opencode-desktop-reset-state --yes"
